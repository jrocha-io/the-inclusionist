# Cabeçalhos do Cloudflare Pages (https://developers.cloudflare.com/pages/configuration/headers/)
# Objetivo: a PWA sempre pega o build novo (sw.js + html sem cache) enquanto assets
# imutáveis (vendor, fontes, sprites) ficam em cache longo. O service worker (bump do
# CACHE a cada commit) cuida do offline; estes cabeçalhos evitam "build velho preso" na borda.

/sw.js
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/manifest.webmanifest
  Cache-Control: no-cache
/js/*
  Cache-Control: no-cache
/css/*
  Cache-Control: no-cache
/vendor/*
  Cache-Control: public, max-age=31536000, immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable
