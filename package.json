{
  "name": "the-inclusionist",
  "version": "4.164.25",
  "private": true,
  "type": "module",
  "description": "The Inclusionist — an accessibility-first (WCAG 2.2) educational 2D pixel-art platformer built with PixiJS; the MVP game of the EdSP educational-game engine for Brazilian basic education.",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && vitest run && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:node": "vitest run --project node",
    "test:browser": "vitest run --project browser",
    "test:a11y": "node scripts/axe-check.mjs",
    "release": "release-it"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^26.1.0",
    "@vitest/browser": "^4.0.0",
    "@vitest/browser-playwright": "^4.0.0",
    "pixi.js": "7.4.2",
    "playwright": "^1.49.0",
    "release-it": "^20.2.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  }
}
