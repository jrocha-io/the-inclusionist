{
  "name": "the-inclusionist",
  "version": "4.164.25",
  "private": true,
  "type": "module",
  "description": "The Inclusionist — jogo educativo a11y-first (PixiJS). Toolchain: Vite (dev/build) + TypeScript (migração incremental, docs/plano-typescript-vite.md) + Vitest. Deploy = dist/ no Cloudflare Pages.",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:node": "vitest run --project node",
    "test:browser": "vitest run --project browser",
    "release": "release-it"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/browser": "^4.0.0",
    "@vitest/browser-playwright": "^4.0.0",
    "pixi.js": "7.4.2",
    "playwright": "^1.49.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  }
}
